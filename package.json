{
  "name": "lecture_develop_001",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:main": "slidev slides.md", 
    "dev:math03": "slidev slides/math03.md", 
    "build:main": "slidev build slides.md --out dist/main --base /main/",
    "build:math03": "slidev build slides/math03.md --out dist/math03 --base /math03/",
    "clean:redirects": "node -e \"const fs=require('fs');['dist/_redirects','dist/main/_redirects','dist/math03/_redirects'].forEach(p=>{if(fs.existsSync(p))fs.rmSync(p,{force:true})})\"",
    "build:all": "npm run build:main && npm run build:math03 && npm run clean:redirects",
    "build": "npm run build:all",
    "build:render": "npm install --no-save @oxc-parser/binding-linux-x64-gnu@0.124.0 && npm run build:all",
    "serve": "npm run build:all && npx serve dist -p 3030",
    "dev": "slidev slides.md --port 3030 --open",
    "export": "slidev export slides.md"
  },
  "dependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "^0.25.0",
    "chart.js": "^4.5.1",
    "vue": "^3.5.29",
    "vue-chartjs": "^5.3.3"
  },
  "optionalDependencies": {
    "@oxc-parser/binding-linux-x64-gnu": "0.124.0",
    "@oxc-parser/binding-win32-x64-msvc": "0.124.0"
  },
  "devDependencies": {
    "playwright-chromium": "^1.59.1"
  }
}
